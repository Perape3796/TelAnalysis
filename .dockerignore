# Build context trimming — keep the image small and the build fast.
.git
.github
.venv
venv
**/__pycache__
*.pyc
.pytest_cache
.ruff_cache

# Frontend deps / build artifacts (rebuilt inside the image)
frontend/node_modules
frontend/dist
frontend/.vite

# Large / local-only data — but keep the two bundled demos so the landing
# screen's "Try demo" buttons work inside the container.
demo/*.json
!demo/personal_demo.json
!demo/group_demo.json
asset
nltk_data
docs/screenshots

# Editor / OS junk
.vscode
.idea
.DS_Store

# Tests aren't needed at runtime
tests
